[Unit]
Description=Marzban Google Docs Sync
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/marzban-sync
EnvironmentFile=/opt/marzban-sync/.env
ExecStart=/usr/bin/python3 /opt/marzban-sync/marzban_sync.py
Restart=always
RestartSec=10
StandardOutput=append:/var/log/marzban_sync.log
StandardError=append:/var/log/marzban_sync.log

[Install]
WantedBy=multi-user.target
